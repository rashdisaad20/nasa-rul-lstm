.pytest_cache/
.coverage
htmlcov/
.coverage.*

# mypy / pylint
.mypy_cache/
.pytype/
.pylint/

# DVC cache
.dvc/cache/
.dvc/tmp/

# IDE-generated files
*.swp
*.swo
*~

