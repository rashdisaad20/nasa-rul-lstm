# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.nasa_venv/

# ⚠️ CRITICAL: Environment variables — NEVER commit secrets
.env
.env.*
.env.local
.env.*.local

# IDE/editor settings
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Model weights — tracked with Git LFS
# Install Git LFS: https://git-lfs.com/
*.pth
*.pt
*.ckpt
mlruns/

# Runtime database files — NOT committed
app.db
mlflow.db
*.sqlite3
*.sqlite

